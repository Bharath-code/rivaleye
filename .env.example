# Dodo Payments (existing)
DODO_PAYMENTS_API_KEY=your_api_key_here
DODO_PAYMENTS_WEBHOOK_KEY=your_webhook_key_here
DODO_PAYMENTS_RETURN_URL=http://localhost:3000
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Dodo product that charges the Pro plan (keep in sync with PLAN_PRICING.pro)
DODO_PRO_PRODUCT_ID=your_pro_product_id

# ══════════════════════════════════════════════════════════════════════════════
# RIVALEYE CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Client-side key. Set EITHER the legacy anon key OR the newer publishable key
# (Supabase renamed `anon` -> `publishable`). The app accepts either name.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Firecrawl (https://firecrawl.dev)
FIRECRAWL_API_KEY=your_firecrawl_api_key

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# AEO Monitor (Answer Engine Optimization)
# Perplexity: get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your_key
# Anthropic: get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key
# Google Gemini: get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key
# SerpAPI (for Google AI Overviews): get from https://serpapi.com/
SERP_API_KEY=your_serpapi_key

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=RivalEye <alerts@yourdomain.com>

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://rivaleye.com/ingress
NEXT_PUBLIC_CLOUDFLARE_BEACON_TOKEN=your_cloudflare_beacon_token_here

# Cloudflare R2 Storage (S3 Compatible)
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=rivaleye-screenshots
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://screenshots.rivaleye.com

# Cloudflare Turnstile (Bot Protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key
TURNSTILE_SECRET_KEY=your_secret_key

# Cron Security (generate a random string)
CRON_SECRET=your_random_secret_for_cron_jobs

# Distributed rate limiting (SEC-5). Without these, rate limiting falls back to
# in-memory (per-instance, ineffective on serverless). Provision an Upstash Redis DB.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# AEO scan cost guardrails (PERF-3) — optional, sensible defaults applied if unset
AEO_MAX_QUERIES_PER_SCAN=10
AEO_SCAN_CONCURRENCY=8
AEO_SCAN_COST_CEILING_USD=0.5
